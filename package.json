{
  "name": "@iammuhammedyazici/tatilbudur-design-system",
  "version": "0.1.1",
  "description": "TatilBudur Design System — icons & components",
  "type": "module",
  "main": "./dist/web/index.js",
  "types": "./dist/web/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./web": {
      "import": "./dist/web/index.js",
      "types": "./dist/web/index.d.ts"
    },
    "./native": {
      "import": "./dist/native/index.js",
      "types": "./dist/native/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iammuhammedyazici/tatilbudur-design-system.git"
  },
"scripts": {
  "clean": "rm -rf dist src/icons",
  "build:icons:web": "svgr --typescript --out-dir src/icons/web src/svg",
  "build:icons:native": "svgr --config-file ./svgr.native.config.cjs --out-dir src/icons/native src/svg",
  "build:icons": "npm run build:icons:web && npm run build:icons:native",
  "build:lib": "tsc --project tsconfig.lib.json",
  "build": "npm run clean && npm run build:icons && npm run build:lib",
  "storybook": "npm run build:icons:web && storybook dev -p 6006",
  "build-storybook": "npm run build:icons:web && storybook build",
  "prepublishOnly": "npm run build"
},
  "keywords": [
    "design-system",
    "icons",
    "react",
    "react-native",
    "tatilbudur"
  ],
  "author": "Muhammed YAZICI",
  "license": "UNLICENSED",
  "peerDependencies": {
    "react": ">=17",
    "react-native-svg": ">=12"
  },
  "peerDependenciesMeta": {
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@svgr/cli": "^8.1.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "^0.85.3",
    "react-native-svg": "^15.15.5",
    "storybook": "^10.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
